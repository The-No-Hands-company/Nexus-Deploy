# === Nexus Deploy Configuration ===

# Public URL of this instance (no trailing slash)
BASE_URL=https://deploy.yourdomain.com

# All deployed apps get: appname.BASE_DOMAIN
BASE_DOMAIN=deploy.yourdomain.com

# Let's Encrypt SSL email
ACME_EMAIL=you@youremail.com

# Data directory — mount a volume here for persistence
DATA_DIR=/workspace

# JWT signing secret — generate: openssl rand -hex 32
JWT_SECRET=change_me_32_chars_minimum

# Database encryption secret — generate: openssl rand -hex 32
APP_SECRET=change_me_32_chars_minimum

# Initial admin credentials (used only on first boot)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_on_first_login

# Docker network name (must match docker-compose.yml)
DOCKER_NETWORK=nexus-net

# Allow new user registration after admin account is created
ALLOW_REGISTRATION=false

# Port for the API server (Traefik handles external routing)
PORT=3000
